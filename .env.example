# BTG Pactual Funds API - Environment Variables
# Copiar este archivo a .env y ajustar los valores

# ===========================================
# APP CONFIGURATION
# ===========================================
APP_NAME=BTG Pactual Funds API
APP_VERSION=1.0.0
DEBUG=true

# ===========================================
# API CONFIGURATION
# ===========================================
API_V1_PREFIX=/api/v1

# ===========================================
# MONGODB CONFIGURATION
# ===========================================
# Local development (Docker)
MONGODB_URL=mongodb://btg_admin:btg_secure_password_2024@localhost:27017
MONGODB_DATABASE=btg_funds

# AWS DocumentDB (Production)
# MONGODB_URL=mongodb://user:password@docdb-cluster.cluster-xxxxx.region.docdb.amazonaws.com:27017/?tls=true&tlsCAFile=rds-combined-ca-bundle.pem&retryWrites=false

# ===========================================
# JWT SECURITY
# ===========================================
# IMPORTANTE: Cambiar en producción
SECRET_KEY=btg-pactual-super-secret-key-change-in-production-2024
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===========================================
# CORS
# ===========================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ===========================================
# BUSINESS RULES
# ===========================================
INITIAL_CLIENT_BALANCE=500000.0

# ===========================================
# NOTIFICATIONS
# ===========================================
NOTIFICATION_EMAIL_ENABLED=true
NOTIFICATION_SMS_ENABLED=true

# ===========================================
# AWS CONFIGURATION (Production)
# ===========================================
AWS_REGION=us-east-1
AWS_SNS_TOPIC_ARN=
AWS_SES_SENDER_EMAIL=
